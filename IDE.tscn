[sub_resource type="GDScript" id="GDScript_gfa64"]
resource_name = "IDE"
script/source = "extends Node
@onready var codeEdit = $Control/HSplitContainer/VSplitContainer/CodeEdit as CodeEdit
@onready var output = $Control/HSplitContainer/VSplitContainer/Output

@onready var VarDbgPanel = $Control/HSplitContainer/DebugPanels/VarScroll/VBoxContainer
@onready var FuncDbgPanel = $Control/HSplitContainer/DebugPanels/FuncScroll/VBoxContainer

var preprocessor: DSPreprocessor = null
var lexer: DSLexer = null
var parser: DSParser = null
var interpreter: DSInterpreter = null
var script_dir = get_script().resource_path.get_base_dir()
var code = \"\"

func _ready() -> void:
	preprocessor = DSPreprocessor.new()
	lexer = DSLexer.new()
	interpreter = DSInterpreter.new()
	interpreter.registerNativeFunc(\"print\",PrintIDE)
	codeEdit.syntax_highlighter = _SyntaxInit()
	pass


func PrintIDE (tx):
	if output.text.is_empty():
		output.text = str(tx)
	else:
		output.text = output.text+\"\\n\"+str(tx)
	pass


func _on_run_btn_pressed() -> void:
	output.text = \"\"
	PrintIDE(\"==========◀DinoSource RUN▶==========\")
	code = codeEdit.text
	print(\"CODE:\\n\"+code)
	var clear_code = preprocessor.process(code,script_dir)
	print(\"\\nPREPROCESSOR:\\n\"+str(clear_code))
	var tokens = lexer.LexerRun(clear_code)
	print(\"\\nTOKENS:\\n\"+str(tokens))
	parser = DSParser.new(tokens)
	parser.source_code = code
	var ast = parser.parse()
	print(\"\\nAST:\\n\"+str(ast))
	interpreter.source_code = code
	var start_time = Time.get_ticks_msec()
	interpreter.run(ast)
	var execution_time_ms = Time.get_ticks_msec() - start_time
	PrintIDE(\"========== END PROGRAMM ==========\")
	PrintIDE(\"⏱️ Execution time: %d ms\" % execution_time_ms)
	_Debug()
	pass # Replace with function body.


func _SyntaxInit() -> CodeHighlighter:
	var syntx = CodeHighlighter.new()
	syntx.add_color_region(\"/*\",\"*/\",Color.DARK_GREEN)
	syntx.add_color_region(\"//\",\"\",Color.DARK_GREEN,true)
	syntx.add_color_region(\"\\\"\",\"\\\"\",Color.BLUE)
	syntx.add_color_region(\"'\",\"'\",Color.BLUE)
	syntx.add_keyword_color(\"true\",Color.BLUE)
	syntx.add_keyword_color(\"false\",Color.BLUE)
	syntx.add_keyword_color(\"int\",Color.BLUE)
	syntx.add_keyword_color(\"float\",Color.BLUE)
	syntx.add_keyword_color(\"bool\",Color.BLUE)
	syntx.add_keyword_color(\"string\",Color.BLUE)
	syntx.add_keyword_color(\"var\",Color.BLUE)
	syntx.add_keyword_color(\"const\",Color.BLUE)
	syntx.add_keyword_color(\"void\",Color.BLUE)
	syntx.add_keyword_color(\"enum\",Color.BLUE)
	syntx.add_keyword_color(\"class\",Color.BLUE)
	syntx.add_keyword_color(\"new\",Color.BLUE)
	syntx.add_keyword_color(\"this\",Color.BLUE)
	syntx.add_keyword_color(\"delete\",Color.BLUE)
	syntx.add_keyword_color(\"POINT\",Color.BLUE)
	syntx.add_keyword_color(\"JMP\",Color.BLUE)
	syntx.add_keyword_color(\"and\",Color.BLUE)
	syntx.add_keyword_color(\"or\",Color.BLUE)
	syntx.add_keyword_color(\"if\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"while\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"repeat\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"case\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"switch\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"default\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"break\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"continue\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"else\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"return\",Color.BLUE_VIOLET)
	syntx.add_keyword_color(\"include\",Color.BLUE_VIOLET)
	syntx.function_color = Color.BLUE_VIOLET
	syntx.number_color = Color.BLUE
	return syntx
	pass


func _Debug():
	for i in VarDbgPanel.get_children():
		i.queue_free()
	for i in FuncDbgPanel.get_children():
		i.queue_free()
	var vars = interpreter.getDebugVariables()
	var funcs = interpreter.getDebugFunctions()
	for v in vars:
		var pnl = preload(\"res://DinoSource/IDE/Panels/var_panel_debug.tscn\").instantiate()
		var nm = pnl.get_node(\"VarName/LineEdit\") as LineEdit
		var _is = pnl.get_node(\"Is/LineEdit\") as LineEdit
		var val = pnl.get_node(\"Value/LineEdit\") as LineEdit
		var type = pnl.get_node(\"Type/LineEdit\") as LineEdit
		nm.text = v.name
		_is.text = \"const\" if v.is_const else \"var\"
		val.text = str(v.value)
		type.text = v.type
		VarDbgPanel.add_child(pnl)
		#var const_mark = \"const\" if v.is_const else \"var\"
		#var array_info = \"\"
		#if v.array_type != null:
			#array_info = \" [%s] size=%d\" % [v.array_type, v.array_size]
		#PrintIDE(\"%s%s: %s = %s%s\" % [const_mark, v.type, v.name, str(v.value), array_info])
	
	for f in funcs:
		var pnl = preload(\"res://DinoSource/IDE/Panels/func_panel_debug.tscn\").instantiate()
		var nm = pnl.get_node(\"VarName/LineEdit\") as LineEdit
		var nat = pnl.get_node(\"Native/LineEdit\") as LineEdit
		var arg = pnl.get_node(\"Arg_cnt/LineEdit\") as LineEdit
		var ret = pnl.get_node(\"Ret/LineEdit\") as LineEdit
		nm.text = f.name
		nat.text = \"YES\" if f.is_native else \"NO\"
		arg.text = str(f.param_count)
		ret.text = f.return_type
		FuncDbgPanel.add_child(pnl)
	pass
"

